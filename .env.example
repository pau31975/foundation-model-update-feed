# ============================================================================
# LLM Provider Update Feed - Environment Configuration
# ============================================================================
# Copy this file to .env and update values as needed.
# The application uses pydantic-settings to load configuration from environment
# variables and this .env file.
#
# For list/array values, use JSON array syntax:
#   EXAMPLE_URLS='["https://url1.com","https://url2.com"]'
#
# ============================================================================
# Database Configuration
# ============================================================================
# SQLite example (default): sqlite:///./data/updates.db
# PostgreSQL example: postgresql://user:password@localhost/dbname
# MySQL example: mysql+pymysql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./data/updates.db

# ============================================================================
# Server Configuration
# ============================================================================
# Server host binding
HOST=127.0.0.1

# Server port
PORT=8000

# Enable auto-reload on code changes (disable in production)
RELOAD=true

# Logging level (debug, info, warning, error, critical)
LOG_LEVEL=info

# ============================================================================
# HTTP Collector Configuration
# ============================================================================
# Timeout in seconds for HTTP requests to provider documentation sites
COLLECTOR_TIMEOUT_SECONDS=30

# Maximum number of retries for failed HTTP requests
COLLECTOR_MAX_RETRIES=2

# ============================================================================
# Feed Pagination Configuration
# ============================================================================
# Default page limit for feed queries
DEFAULT_PAGE_LIMIT=50

# Maximum allowed page limit for feed queries
MAX_PAGE_LIMIT=200

# ============================================================================
# Provider Source URLs
# ============================================================================
# Use JSON array format for multiple URLs. If a provider has multiple sources,
# the collector will fetch from all URLs.

# Google Gemini API sources (Gemini API docs + Vertex AI generative AI docs)
GEMINI_SOURCE_URLS=["https://ai.google.dev/gemini-api/docs/deprecations","https://ai.google.dev/gemini-api/docs/changelog","https://cloud.google.com/vertex-ai/generative-ai/docs/learn/model-versions","https://cloud.google.com/vertex-ai/generative-ai/docs/release-notes"]

# OpenAI API sources
OPENAI_SOURCE_URLS=["https://platform.openai.com/docs/deprecations"]

# Anthropic Claude API sources
ANTHROPIC_SOURCE_URLS=["https://docs.anthropic.com/en/docs/about-claude/models/all-models","https://docs.anthropic.com/en/release-notes/api"]

# Azure OpenAI API sources
AZURE_SOURCE_URLS=["https://learn.microsoft.com/en-us/azure/ai-services/openai/concepts/models","https://learn.microsoft.com/en-us/azure/ai-services/openai/whats-new"]

# AWS Bedrock sources
AWS_SOURCE_URLS=["https://docs.aws.amazon.com/bedrock/latest/userguide/model-lifecycle.html","https://docs.aws.amazon.com/bedrock/latest/userguide/doc-history.html"]
